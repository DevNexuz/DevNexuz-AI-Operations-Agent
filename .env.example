# AI Operations Agent — Environment Configuration
#
# Copy this file to .env and fill in the values for your chosen provider.
# Only ONE provider needs to be configured at a time.
#
#   cp .env.example .env

# -----------------------------------------------------------------------------
# Required: choose your LLM provider
# Valid values: groq | openai | anthropic | xai | gemini | ollama
# Default if not set: groq
# -----------------------------------------------------------------------------
LLM_PROVIDER=groq

# Optional: override the default model for your provider.
# If not set, the agent uses a sensible default per provider (see below).
# LLM_MODEL=

# Output language for generated reports: en | es  (default: es)
REPORT_LANGUAGE=es

# -----------------------------------------------------------------------------
# Provider API keys — fill in only the one you're using.
# -----------------------------------------------------------------------------

# Groq — free tier, very fast. Default model: llama-3.3-70b-versatile
# Get your key: https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# OpenAI — paid. Default model: gpt-4o-mini
# Get your key: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# Anthropic Claude — paid. Default model: claude-3-5-haiku-20241022
# Get your key: https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# xAI (Grok) — free tier. Default model: grok-3-mini
# Get your key: https://console.x.ai/
XAI_API_KEY=your_xai_api_key_here

# Google Gemini — generous free tier. Default model: gemini-2.0-flash
# Get your key: https://aistudio.google.com/apikey
GOOGLE_API_KEY=your_google_api_key_here

# Ollama — local, fully free, no key needed.
# Install: https://ollama.com/ — then run: ollama pull llama3.1
# Default model: llama3.1
OLLAMA_BASE_URL=http://localhost:11434
